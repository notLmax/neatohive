{
  "name": "neato-hive",
  "version": "1.5.24",
  "description": "Personal AI agent runtime — Claude Agent SDK + Codex MCP + Discord",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "main": "dist/index.js",
  "bin": {
    "hive": "./bin/hive"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
