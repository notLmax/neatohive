# Neato Hive — Environment Variables
#
# This file documents every env variable the framework recognizes.
# On fresh install, setup.sh copies this to .env and prompts for required values.
#
# Sections (read by `hive doctor` for the `.env key coverage` check):
#   === REQUIRED ===   Hive will not function without these. doctor WARNs if missing.
#   === OPTIONAL ===   Only needed for specific integrations. doctor is silent.
#   === DEPRECATED === Old keys preserved for v1.4.x back-compat. New installs should
#                      NOT set these — they have been replaced by config/*.yaml.

# ============================================================
# === REQUIRED ===
# Hive will not function without these.
# ============================================================

# Per-agent Discord bot tokens. One per agent process.
# Variable-name pattern: DISCORD_BOT_TOKEN_<AGENT_NAME_UPPERCASE>
# Hyphens become underscores: house-md → DISCORD_BOT_TOKEN_HOUSE_MD
# Get the token from the Discord Developer Portal:
#   https://discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_BOT_TOKEN_HOUSE_MD=

# ============================================================
# === OPTIONAL ===
# Only needed for specific integrations. `hive doctor` is silent
# when these are unset — set only if you use the feature.
# ============================================================

# Working directory — where agents operate on projects.
# Default if unset: ~/projects
WORKING_DIR=~/projects

# 1Password Service Account Token. Only set if you want agents to fetch
# credentials via `op read` from a 1Password vault. Create vault + service
# account in the 1Password web UI. See shared/CREDENTIALS.md for setup.
OP_SERVICE_ACCOUNT_TOKEN=

# Name of the 1Password vault the service-account token has access to.
# Required only if OP_SERVICE_ACCOUNT_TOKEN is set.
OP_VAULT_NAME=

# Dashboard bridge target.
# Default behavior (var unset or empty): each agent connects to its own
#   ws://127.0.0.1:7777/ws/agent/<agent-name> endpoint on the local dashboard.
# Override (set to a non-empty URL): point all agents at an alternate dashboard
#   host. Useful when running multiple Hives or pointing at a remote dashboard.
# To fully disable the dashboard bridge (no chat mirror), set LOCAL_BRIDGE_DISABLED=true.
LOCAL_BRIDGE_URL=

# Dashboard bridge opt-out.
# Set to "true" to disable the dashboard chat bridge entirely (no agent↔dashboard
# WebSocket connection, no chat-mirror to Discord). Default: unset (bridge enabled).
LOCAL_BRIDGE_DISABLED=

# Dashboard auth gate.
# Default false: dashboard is reachable locally on 127.0.0.1, and Tailscale Serve exposure remains opt-in.
# Set true only if your tailnet has untrusted members and you want every dashboard route to require the saved token.
DASHBOARD_REQUIRE_AUTH=false

# ============================================================
# === DEPRECATED (v1.4.7) ===
# These env vars were replaced by config/users.local.yaml. They still work
# for v1.4.x back-compat but will be removed in v1.6.x. DO NOT SET on new
# installs — create config/users.local.yaml with a `users:` array instead.
# Reference: shared/CREDENTIALS.md and the v1.4.7 user-identity work.
# ============================================================

# DISCORD_OWNER_ID=
# DISCORD_AUTHORIZED_USERS=
